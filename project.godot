; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Second Set"
config/description="Get the key to open the vault, and run back home with the goodies!"
config/version="0.1.0"
run/main_scene="uid://b8qsr26uos21x"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor]

movie_writer/video_quality=0.65
movie_writer/movie_file="E:/replay.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg")

